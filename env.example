# CMR — Variables de entorno
# Copiar este archivo como .env.local y completar los valores
# NUNCA commitear .env.local al repositorio
# Las keys de producción viven solo en Vercel / Railway como env vars del servicio

# ─── SUPABASE ────────────────────────────────────────────────────────────────
# Obtener en: https://supabase.com → proyecto → Settings → API
NEXT_PUBLIC_SUPABASE_URL=                   # https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=              # Clave pública para login y queries con RLS
SUPABASE_SERVICE_ROLE_KEY=                  # ⚠️ Solo backend/webhooks. NUNCA exponer al cliente.

# ─── WHATSAPP CLOUD API ───────────────────────────────────────────────────────
# Obtener en: https://developers.facebook.com → My Apps → WhatsApp → Getting Started
WHATSAPP_PHONE_NUMBER_ID=                   # ID del número de teléfono en Meta
WHATSAPP_ACCESS_TOKEN=                      # Token de acceso permanente
WHATSAPP_WEBHOOK_VERIFY_TOKEN=              # String aleatorio que vos elegís para verificar el webhook

# ─── TELEGRAM ─────────────────────────────────────────────────────────────────
# Obtener en: Hablar con @BotFather en Telegram → /newbot
TELEGRAM_BOT_TOKEN=                         # formato: 123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# ─── INSTAGRAM / META GRAPH API ───────────────────────────────────────────────
# Obtener en: https://developers.facebook.com → mismo app que WhatsApp
META_APP_SECRET=                            # Para verificar firma de webhooks
META_PAGE_ACCESS_TOKEN=                     # Token de la página de Facebook/Instagram

# ─── IA ───────────────────────────────────────────────────────────────────────
# Groq (gratis): https://console.groq.com → API Keys
GROQ_API_KEY=                               # gsk_xxxx...
# OpenAI (Fase 2 solamente): https://platform.openai.com → API Keys
OPENAI_API_KEY=                             # sk-xxxx...

# ─── REDIS — UPSTASH ──────────────────────────────────────────────────────────
# Obtener en: https://upstash.com → Create Database → Redis
UPSTASH_REDIS_REST_URL=                     # https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=                   # Token de acceso REST

# ─── EMAIL — RESEND ───────────────────────────────────────────────────────────
# Obtener en: https://resend.com → API Keys
RESEND_API_KEY=                             # re_xxxx...
RESEND_FROM_EMAIL=                          # ej: noreply@tudominio.com

# ─── PAGOS ────────────────────────────────────────────────────────────────────
# Stripe: https://dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=                          # sk_test_xxxx (test) o sk_live_xxxx (prod)
STRIPE_WEBHOOK_SECRET=                      # whsec_xxxx — obtener al crear webhook en Stripe

# ─── ENTORNO ──────────────────────────────────────────────────────────────────
NODE_ENV=development                        # development | production
NEXT_PUBLIC_APP_URL=http://localhost:3000   # URL base de la app
DEFAULT_TENANT_ID=                          # UUID fallback para automatizaciones/backend como el webhook
CHATWOOT_APP_URL=http://localhost:3000      # URL de Chatwoot o inbox principal
CHATWOOT_WEBHOOK_SECRET=                    # Token esperado en x-chatwoot-token
